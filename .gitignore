# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (next.js / node)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/excoveralls
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt string template cache
.grunt

# Bower dependency directory (deprecated but good to keep)
bower_components

# Node modules (Dependencies)
node_modules/
jspm_packages/

# Snowpack dependency directory (deprecated)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Output directory generated by vite (Production build)
dist/
dist-ssr/

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Tern device definitions
.tern-port

# Stores VS Code state and extensions
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.history/
*.code-workspace

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/

# Local env files (Contains sensitive API keys / credentials)
.env
.env.local
.env.[a-zA-Z0-9]*
!.env.example

# OS generated files
.DS_Store
Thumbs.db
